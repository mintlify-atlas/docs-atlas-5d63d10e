  "keyFeatures": [
    "High-performance validator with low-latency architecture from trading systems",
    "Kernel bypass networking with AF_XDP for maximum throughput",
    "Tile-based architecture for security isolation and performance",
    "Custom AVX512 cryptographic implementations (ED25519, SHA-512)",
    "Frankendancer hybrid mode with Agave for incremental deployment",
    "Strict sandboxing with seccomp for security",
    "Independent C implementation for client diversity",
    "CLI-based validator management with fdctl"
  ],
  "publicApiSurface": [
    "fdctl run - Run the validator",
    "fdctl monitor - Monitor validator performance",
    "fdctl configure - Configure system for Firedancer",
    "fdctl keys - Manage validator keys",
    "Ballet - Cryptographic primitives library",
    "Disco - Distributed compute and networking tiles",
    "Flamenco - Solana protocol implementation",
    "Tango - Inter-process communication framework",
    "Waltz - Network protocol implementations",
    "Metrics API - Prometheus-compatible metrics",
    "WebSocket API - Real-time validator status"
  ]
}
